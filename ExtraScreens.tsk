        <span className="font-display font-semibold text-white text-base">Rewards</span>
        <div className="w-5 h-5"></div>
      </div>
      <div className="bg-gradient-to-br from-brand-blue/30 to-brand-cyan/20 border border-brand-blue/30 rounded-2xl p-4 text-center mb-5">
        <Gift className="w-8 h-8 text-brand-cyan mx-auto mb-2 animate-bounce" />
        <span className="text-[11px] uppercase text-brand-cyan font-semibold">Ciscolyn Points</span>
        <h2 className="text-white text-xl font-display font-extrabold mt-1">1,250 PTS</h2>
      </div>

      <div className="space-y-2.5 text-left">
