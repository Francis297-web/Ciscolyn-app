              <span className="text-xs text-white font-bold block">100 KES Airtime Voucher</span>
              <span className="text-[9px] text-gray-400">Cost: 500 PTS</span>
            </div>
          </div>
          <button className="bg-brand-blue text-white text-[10px] font-bold px-3 py-1.5 rounded-lg">Redeem</button>
